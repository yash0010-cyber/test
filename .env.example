# Application Environment Configuration
# Copy this file to .env and update with your values

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=house_rental

# Application Configuration
APP_URL=http://localhost:8000
APP_NAME=House Rental Management System
APP_ENV=production
APP_DEBUG=false

# Email Configuration (Gmail)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM_ADDRESS=your_email@gmail.com
MAIL_FROM_NAME=House Rental System

# Security Keys
JWT_SECRET=change_this_to_a_random_string_min_32_chars
ENCRYPTION_KEY=change_this_to_a_random_string_min_32_chars

# Session Configuration
SESSION_LIFETIME=1440
SESSION_SECURE=false
SESSION_HTTP_ONLY=true

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp
UPLOAD_PATH=public/uploads

# Application Timezone
APP_TIMEZONE=UTC

# Pagination
ITEMS_PER_PAGE=10

# Email Verification
EMAIL_VERIFICATION_REQUIRED=true
EMAIL_VERIFICATION_EXPIRY=24

# Password Reset
PASSWORD_RESET_TOKEN_EXPIRY=1
PASSWORD_RESET_TOKEN_LENGTH=32

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_TIMEOUT=900
