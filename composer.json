{
    "name": "yash0010-cyber/house-rental-system",
    "description": "Production-ready House Rental Management System with PHP 8.x, MySQL, and Bootstrap",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.0",
        "phpmailer/phpmailer": "^6.8",
        "vlucas/phpdotenv": "^5.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "config/constants.php",
            "app/utils/Helper.php"
        ]
    },
    "scripts": {
        "serve": "php -S localhost:8000 -t public",
        "test": "phpunit",
        "db-migrate": "php scripts/migrate.php",
        "db-seed": "php scripts/seed.php"
    },
    "authors": [
        {
            "name": "Development Team",
            "email": "dev@example.com"
        }
    ],
    "keywords": [
        "php",
        "house-rental",
        "property-management",
        "mysql",
        "bootstrap"
    ]
}
